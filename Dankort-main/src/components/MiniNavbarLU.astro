---
const { active } = Astro.props;
---

<a href="/" class="login-link">
  Log ind
</a>

<section class="tabs-wrapper">

  <nav class="tabs">
    
    <a 
      href="/velkommen" 
      class={`tab ${active === "velkommen" ? "active" : ""}`}
    >
      Velkommen
    </a>

    <a 
      href="/fordele" 
      class={`tab ${active === "fordele" ? "active" : ""}`}
    >
      Fordele
    </a>

    <a 
      href="/oere" 
      class={`tab ${active === "oere" ? "active" : ""}`}
    >
      Om Øremærket
    </a>

  </nav>

</section>

<style>
  * {
    box-sizing: border-box;
    font-family: raleway, sans-serif;
  }

  .login-link {
    position: absolute;

    top: 130px;
    right: 16px;

    text-decoration: none;

    font-size: 16px;
    font-weight: 700;

    color: #E21E27;

    z-index: 10;
  }

  .tabs-wrapper {
    position: fixed;

    bottom: 0;
    left: 0;

    width: 100%;

    background: #f5f5f5;

    display: flex;
    justify-content: center;

    padding: 16px;

    z-index: 1;
  }

  .tabs {
    width: 100%;
    max-width: 700px;

    display: flex;
    justify-content: center;
    gap: 40px;

    border-bottom: 2px solid #d9d9d9;
  }

  .tab {
    position: relative;

    text-decoration: none;
    color: #111;

    padding-bottom: 14px;

    white-space: nowrap;

    font-size: 14px;
  }

  .tab.active::after {
    content: "";

    position: absolute;
    left: 0;
    bottom: -2px;

    width: 100%;
    height: 3px;

    background: #e31b23;
  }

  @media (min-width: 768px) {

    .login-link {
      right: 40px;
      font-size: 16px;
    }

    .tabs-wrapper {
      position: relative;

      padding-top: 48px;
      padding-bottom: 40px;

      background: white;
    }

    .tabs {
      max-width: 560px;
      gap: 145px;
    }

    .tab {
      font-size: 16px;
      padding-bottom: 18px;
    }
  }
</style>