---

<section class="login-screen">
  <div class="logo-wrapper">
    <img src="/images/DankortLogo.png" alt="Dankort logo" class="logo" />
  </div>

  <div class="welcome">
    <p>Velkommen til</p>
    <h1>Dankort Øremærket</h1>
  </div>

  <div class="tabs">
    <button class="tab active">Log ind</button>
    <button class="tab">Opret konto</button>
  </div>

  <form class="login-form">
    <div class="input-group">
      <input type="text" placeholder="E-mail eller brugernavn" />
    </div>

    <div class="input-group password-group">
      <input type="password" placeholder="Adgangskode" />

    </div>

    <a href="#" class="forgot-password">Glemt adgangskode?</a>


  </form>
<a href="/velkommen" class="login-btn" id="loginBtn">
  Log ind
</a>
<a href="/velkommen" class="guest-btn" id="guestBtn">
  Fortæt som gæst
</a>
  <div class="privacy">
   

    <p>
      Vi passer godt på dine data. Læs mere i vores
      <span>privathedspolitik</span>
    </p>
  </div>
</section>

<style>
  .login-screen {
    min-height: 100vh;
   
    background: #f3f3f3;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 24px 32px;
    
  }

  .logo-wrapper {
    margin-top: 10px;
  }

  .logo {
    width: 150px;
    object-fit: contain;
  }

  .welcome {
    text-align: center;
    margin-top: 10px;
  }

  .welcome p {

    color: #111;
    margin-bottom: 28px;
    font-size: 20px;
  }

  .welcome h1 {

    color: #000;
  }

  .tabs {
    width: 100%;
    max-width: 620px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-top: 90px;
    border-bottom: 2px solid #d8d8d8;
  }

  .tab {
    background: none;
    border: none;
    padding: 0 0 20px;
   font-size: 16px;
    cursor: pointer;
    position: relative;
  }

  .tab.active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 4px;
    background: #ef1722;
  }

  .login-form {
    width: 100%;
    max-width: 620px;
    margin-top: 55px;
    display: flex;
    flex-direction: column;
  }

  .input-group {

    background: transparent;
    border: 2px solid #d3d3d3;
    border-radius: 22px;
    padding: 20px 80px 20px 10px;

    display: flex;
    align-items: center;

    margin-bottom: 10px;
  }

  .input-group input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    color: #111;
  }

  .input-group input::placeholder {
    color: #9c9c9c;

  }

  .password-group {
    justify-content: space-between;
  }



  .forgot-password {
   
    color: #000;
    text-decoration: none;
    margin-left: 12px;
  }

.login-btn {
  margin: 50px auto 0;
padding: 20px 60px;

  border-radius: 20px;
  border: 1px solid #111;
  background: #ef1722;
  color: white;
  font-family: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: 0.2s ease;
}

  .login-btn:hover {
    transform: translateY(-2px);
  }

  .guest-btn {
  margin: 0px auto 0;
padding: 20px 60px;

  border-radius: 20px;


  color: rgb(0, 0, 0);
  font-family: inherit;
  display: flex;
  align-items: center;
  justify-content: center;

  cursor: pointer;
  transition: 0.2s ease;
}

  .guest-btn:hover {
    transform: translateY(-2px);
  }

  .privacy {
    margin-top: 20px;

    display: flex;
    align-items: center;
    gap: 12px;
    color: #8b8b8b;

    text-align: center;
  }

  .privacy span {
    color: #111;

  }

  @media (min-width: 768px) {
   .welcome{
    margin-top: 0;
   }
   .login-screen{padding-top: 0;}



}
</style>

<script>
  const loginBtn = document.getElementById("loginBtn");
  const guestBtn = document.getElementById("guestBtn");

  loginBtn?.addEventListener("click", () => {
    localStorage.setItem("userType", "bruger");
  });

  guestBtn?.addEventListener("click", () => {
    localStorage.setItem("userType", "guest");
  });
</script>